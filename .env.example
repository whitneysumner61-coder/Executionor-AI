# ═══════════════════════════════════════════════════════
# EXECUTIONOR v1.1 — Environment Configuration
# Edit this file then restart the server, OR use the
# Settings panel in the UI (⚙ button) to set keys live.
# ═══════════════════════════════════════════════════════

# Server port (default 3100)
PORT=3100

# ── Local mode ───────────────────────────────────────────
# No paid AI API key is required. The local router uses
# real PowerShell, filesystem, database, and OpenClaw data.
WORKSPACE_ROOT=

# ── OPTIONAL: Supabase (for DB panel) ──────────────────
# Found in: Supabase → Project Settings → API
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# ── OPTIONAL: Raw SQL support ───────────────────────────
# Found in: Supabase → Settings → Database → Connection string → URI
# Enables any SQL query (not just table SELECTs)
SUPABASE_DB_URL=

# ── OpenClaw gateway ───────────────────────────────────
# These defaults work if your gateway is running locally
OPENCLAW_RELAY_URL=http://localhost:4588
OPENCLAW_BRIDGE_URL=http://localhost:3004
OPENCLAW_GATEWAY_TOKEN=

# ── Dashboard auth token ────────────────────────────────
DASHBOARD_TOKEN=executionor-local
